graph TD

  subgraph Orchestrator[poc-food-supply-chain]
    flows[flows and src/flows]
    adapters[adapters and src/adapters]
    scripts[src/scripts]
    data[data and src/flows/output]
  end

  subgraph VC[vc submodule]
    vccli[dist/cli.js setup issue verify]
  end

  subgraph Anchors[secuweb-anchors submodule]
    hh[Hardhat runtime]
    reg[DIDRegistry contract]
    ascripts[scripts anchorVc exploreChain verifyVc]
  end

  subgraph External
    solid[Solid Pod]
    hhn[Hardhat node localhost:8545]
    verifier[Verifier client]
  end

  %% Orchestration
  flows --> adapters
  flows --> data
  scripts --> adapters

  %% VC plane (off-chain)
  adapters --> vccli
  vccli --> solid
  vccli --> data

  %% Anchoring plane (on-chain)
  adapters --> ascripts
  ascripts --> reg
  reg --- hhn

  %% Verification consumers
  verifier --> solid
  verifier --> reg