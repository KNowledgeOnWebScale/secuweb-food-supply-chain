{
  "name": "poc-food-supply-chain",
  "version": "1.0.0",
  "main": "index.js",
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "start": "npm run build && node build/index.js",
    "dev": "nodemon --config nodemon.json --exec npm run start",
    "ff": "npm run build && node build/bc/ff.js",
    "ff:dev": "nodemon --config nodemon.json --exec npm run ff",
    "pod": "community-solid-server --rootFilePath ./css/root --config ./css/css.json --seedConfig ./css/css-users.json",
    "add-firefly-did-to-webid-profile": "npm run build && node build/css/add-firefly-did-to-webid-profile.js",
    "scratch": "npm run build && node build/scratch.js",
    "scratch:dev": "nodemon --config nodemon.json --exec npm run scratch",
    "flows:create-vc": "npm run build && node build/flows/create-vc.js",
    "flows:add-file-to-solid-pod": "npm run build && node build/flows/add-file-to-solid-pod.js",
    "flows:set-acl": "npm run build && node build/flows/set-acl.js"
  },
  "config": {
    "community-solid-server": {
      "port": 3000,
      "loggingLevel": "info"
    }
  },
  "author": "Gertjan De Mulder (gertjan.demulder@ugent.be)",
  "license": "MIT",
  "description": "",
  "dependencies": {
    "@fastify/cors": "^11.1.0",
    "@fastify/formbody": "^8.0.2",
    "@fastify/helmet": "^13.0.1",
    "@fastify/swagger": "^9.5.1",
    "@fastify/swagger-ui": "^5.2.3",
    "@fastify/type-provider-typebox": "^6.0.0",
    "@hyperledger/firefly-sdk": "^1.3.3",
    "@inrupt/solid-client": "^2.1.2",
    "@inrupt/solid-client-authn-core": "^3.1.0",
    "@inrupt/universal-fetch": "^1.0.3",
    "@sinclair/typebox": "^0.34.41",
    "commander": "^14.0.1",
    "fastify": "^5.6.1",
    "json-schema-to-ts": "^3.1.1"
  },
  "devDependencies": {
    "@solid/community-server": "^7.1.7",
    "@types/node": "^24.5.2",
    "nodemon": "^3.1.10",
    "typescript": "^5.9.2"
  }
}
