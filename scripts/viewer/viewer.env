export OUR_CLONE=$(basename $(pwd))
export VIEWER_REPO=miravi-a-linked-data-viewer
export VIEWER_CLONE=food-supply-chain-miravi
export VIEWER_CLONE_URI="https://github.com/SolidLabResearch/miravi-a-linked-data-viewer.git"
export VIEWER_CLONE_BRANCH="secuweb/demonstrator"

# FLAGS
export SAFEGUARD_VIEWER_CLONE=false

# absolute dir
export OUR_ROOT_DIR=$(pwd)/../..

# Helper
function clone() {
    echo "Cloning $VIEWER_REPO into $VIEWER_CLONE..."
    git clone $VIEWER_CLONE_URI -b $VIEWER_CLONE_BRANCH ${VIEWER_CLONE}
}