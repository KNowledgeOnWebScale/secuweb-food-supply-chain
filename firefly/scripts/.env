FPATH_BASE=$PWD
FPATH_DIR_FIREFLY_SCRIPTS=$FPATH_BASE/firefly/scripts
FPATH_DIR_FIREFLY_OUTPUT=$FPATH_DIR_FIREFLY_SCRIPTS/output
FPATH_IDENTITIES=$FPATH_DIR_FIREFLY_OUTPUT/identities.json
FPATH_DIR_KEYS=$FPATH_DIR_FIREFLY_OUTPUT/keys/
FPATH_CSS_USERS=$FPATH_BASE/css/css-users.json

echo "creating dir (FPATH_DIR_FIREFLY_OUTPUT): $FPATH_DIR_FIREFLY_OUTPUT"
mkdir -p $FPATH_DIR_FIREFLY_OUTPUT

echo "creating dir (FPATH_DIR_KEYS): $FPATH_DIR_KEYS"
mkdir -p $FPATH_DIR_KEYS